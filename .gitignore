# Environment variables and local secrets
.env
.env.*
!.env.example

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local databases and runtime data
data/*
!data/.gitkeep
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Generated evaluation and application output
output/*
!output/.gitkeep
*.log

# Packaging and build output
build/
dist/
*.egg-info/

# IDE and operating-system files
.idea/
.vscode/
.DS_Store
Thumbs.db

