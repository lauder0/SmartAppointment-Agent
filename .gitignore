# Environment variables and local secrets
.env
.env.*
!.env.example

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python cache and build output
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/
*.egg-info/

# Local databases and runtime state
data/*
!data/.gitkeep
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Logs and generated reports
output/*
!output/.gitkeep
*.log

# IDE and OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db
