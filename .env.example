# Model provider: azure, openai, qwen, deepseek, zhipu, or openai-compatible
MODEL_PROVIDER=qwen

# OpenAI-compatible chat model
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Embedding provider
EMBEDDING_PROVIDER=qwen
EMBEDDING_API_KEY=replace-with-your-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# Optional weather integration
OPENWEATHER_API_KEY=

# Session persistence: memory or redis
SESSION_BACKEND=memory
SESSION_TTL_SECONDS=7200
REDIS_URL=redis://localhost:6379/0
SESSION_KEY_PREFIX=smart_appointment:session
SESSION_LOCK_TIMEOUT_SECONDS=30
SESSION_LOCK_BLOCKING_TIMEOUT_SECONDS=5

# Azure OpenAI settings, required only when MODEL_PROVIDER=azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_VERSION=
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=
AZURE_OPENAI_ENDPOINT_EMBEDDING=
AZURE_OPENAI_EMBEDDING_VERSION=2023-05-15

